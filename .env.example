# ── Payload CMS ─────────────────────────────────────────────
# Secret largo, único, no compartible. Generá uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=

# Cadena de conexión a Supabase Postgres.
# 1. Entrá a tu proyecto en https://supabase.com
# 2. Project Settings → Database → Connection string → "URI"
# 3. IMPORTANTE: usá el pooler en "Session mode" en puerto 5432
#    (NO el "Transaction mode" en 6543 — Payload necesita session).
# 4. Reemplazá [YOUR-PASSWORD] por la contraseña del proyecto.
# Formato típico:
#   postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
DATABASE_URI=

# ── Supabase (auth + storage — opcional por ahora) ──────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Sitio ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Dev LAN (opcional, solo para acceder al dev server desde otro
# dispositivo en la misma red WiFi — ej: el celu para probar Quick Add) ──
# Hosts de la red local sin protocolo ni puerto, separados por coma.
# Para ver la IP de tu máquina:
#   Windows → ipconfig → IPv4 del adaptador WiFi
#   macOS → System Settings → Network → WiFi → IP address
# Ej: NEXT_DEV_LAN_HOSTS=10.10.10.102,192.168.1.20
NEXT_DEV_LAN_HOSTS=
